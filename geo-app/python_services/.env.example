# ================================================================
# .env.example - Plantilla de Variables de Entorno
# ================================================================
# INSTRUCCIONES:
#   1. Copiar este archivo como .env:  cp .env.example .env
#   2. Rellenar TODOS los valores reales
#   3. NUNCA subir .env a Git (ya está en .gitignore)
#   4. Rotar credenciales cada 90 días mínimo
# ================================================================

# ==================== Supabase ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==================== PostgreSQL ====================
POSTGRES_HOST=your-db-host.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres.your-project
POSTGRES_PASSWORD=your-strong-password-here

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=4

# ==================== Scraper ====================
SCRAPER_DELAY_SECONDS=2
SCRAPER_MAX_RETRIES=3
SCRAPER_HEADLESS=true
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ==================== ML Model ====================
MODEL_PATH=./ml_model/models
MODEL_RETRAIN_DAYS=30
MIN_TRAINING_SAMPLES=50

# ==================== INEGI ====================
INEGI_API_TOKEN=your-inegi-token-here
INEGI_BASE_URL=https://www.inegi.org.mx/app/api/indicadores/

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ==================== Security ====================
# API key for protecting sensitive endpoints (e.g. /train)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-api-key-here

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Rate Limiting ====================
MAX_REQUESTS_PER_HOUR=100
